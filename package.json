{
  "name": "@vectoramp/cli",
  "version": "0.1.0",
  "description": "Command-line interface for VectorAmp datasets, ingestion, search, and Intelligence.",
  "type": "module",
  "bin": {
    "vectoramp": "./dist/index.js",
    "va": "./dist/index.js"
  },
  "files": [
    "dist",
    "scripts/install.sh",
    "README.md",
    "LICENSE"
  ],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": ["vectoramp", "cli", "sable", "rag", "vector-database"],
  "author": "VectorAmp",
  "license": "UNLICENSED",
  "repository": { "type": "git", "url": "git+ssh://git@gitlab.com/VectorAmp/SDK/CLI.git" },
  "bugs": { "url": "https://gitlab.com/VectorAmp/SDK/CLI/-/issues" },
  "homepage": "https://vectoramp.com",
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "publishConfig": { "access": "public" }
}
